# Normalise line endings to LF in the repository on all platforms.
* text=auto eol=lf

# PHP, JS, CSS, HTML — always LF
*.php   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.pot   text eol=lf

# Binaries — no conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.zip   binary
*.pdf   binary
*.mjs   binary
